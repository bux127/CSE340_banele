<%- include('partials/header') %>
<main>
    <% if (user && user.role_name === 'admin') { %>
    <p><a href="/edit-project/<%= project.project_id %>">Edit Project</a></p>
<% } %>
    
    <h1><%= title %></h1>
    <p><strong>Description:</strong></p>
    <p><%= project.description %></p>
    
    <p><strong>Date:</strong> <%= new Date(project.date).toLocaleDateString() %></p>
    <p><strong>Location:</strong> <%= project.location %></p>
    
    <p><strong>Partner Organization:</strong> 
        <a href="/organization/<%= project.org_id %>">
            <%= project.organization_name %>
        </a>
    </p>

    <br>
    <a href="/projects"> Upcoming Projects</a>
    <a href="/assign-categories/<%= project.project_id %>">Edit Categories</a>


</main>
<%- include('partials/footer') %>