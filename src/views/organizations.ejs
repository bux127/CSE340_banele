
    <%- include('partials/header') %>
    <main>
        <h1><%= title %></h1>
        <p>Here are a few of our partner organizations:</p>
<ul>
    <% organizations.forEach(organization => { %>
    <li>
        <li><img src="/images/<%= organization.logo_name %>" alt="<%= organization.logo_name %> logo"><a href="/organization/<%= organization.organization_id %>"><%= organization.name %></a>: <%= organization.email %></li>
        
    </li>
    <%})%>
</ul>
    </main>
<%- include('partials/footer') %>

