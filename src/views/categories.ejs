
    <%- include('partials/header') %>
    <main>
        <h1><%= title %></h1>
 
 <% if (user && user.role_name === 'admin') { %>
    <p><a href="/new-category/<%= categories.cart_id %>">Add New Category</a></p>    
<% } %>       
        
<ul>
    <% categories.forEach(category => { %>
        
    <li><a href="/category/<%= category.cart_id %>"><%= category.name %></a>
       
    </li>
    
    <%})%>
    
</ul>
<p><a href="/categories"> View Service Projects</a></p>
    </main>
<%- include('partials/footer') %>

